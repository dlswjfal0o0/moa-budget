require "shellwords"

default_platform(:ios)

# 이 lane은 CI(GitHub Actions) 전용이다. 로컬 Xcode 개발 환경은
# CODE_SIGN_STYLE = Automatic을 그대로 쓰고(project.pbxproj), 여기서는
# update_code_signing_settings로 App 타겟의 CI 체크아웃 사본만 수동 서명으로
# 바꿔서 로컬 개발에는 영향이 없다 (커밋되어 돌아가지 않는, 그 실행 한정 변경).
#
# fastlane match 대신 GitHub Secrets에 base64로 저장해둔 배포용 인증서(.p12)와
# 프로비저닝 프로파일(.mobileprovision)을 매 실행마다 임시 키체인에 import한다 —
# 별도 인증서 저장 저장소를 관리할 필요가 없는, 개인 프로젝트 규모에 맞는 방식.
platform :ios do
  desc "Build and upload a release build to TestFlight"
  lane :beta do
    keychain_password = ENV.fetch("IOS_CI_KEYCHAIN_PASSWORD")
    keychain_name = "ci-signing.keychain-db"

    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
    )

    # A fresh CI keychain has no trust chain for Apple's own certificates.
    # codesign/xcodebuild don't seem to mind locally, but App Store
    # Connect's server-side validation rejects the upload as "not signed
    # using an Apple submission certificate" without the WWDR
    # intermediate present to complete the chain.
    keychain_path = File.expand_path("~/Library/Keychains/#{keychain_name}")
    ["AppleWWDRCAG3.cer", "AppleWWDRCAG2.cer"].each do |wwdr_cert|
      wwdr_path = File.join(Dir.mktmpdir, wwdr_cert)
      sh("curl -sSL -o #{wwdr_path.shellescape} https://www.apple.com/certificateauthority/#{wwdr_cert}")
      sh("security import #{wwdr_path.shellescape} -k #{keychain_path.shellescape} -A")
    end

    # Bypassing fastlane's import_certificate action here — it has
    # consistently reported "MAC verification failed (wrong password?)"
    # across several independently-generated certificates/passwords that
    # all verified fine locally with openssl, which points at the action's
    # wrapper rather than the actual credentials. Shelling out to
    # `security import` directly (same as the WWDR imports above, which
    # have never failed) rules that out.
    cert_path = File.join(Dir.mktmpdir, "dist_certificate.p12")
    File.binwrite(cert_path, Base64.decode64(ENV.fetch("IOS_DIST_CERTIFICATE_BASE64")))
    cert_password = ENV.fetch("IOS_DIST_CERTIFICATE_PASSWORD")
    sh("security import #{cert_path.shellescape} -k #{keychain_path.shellescape} -P #{cert_password.shellescape} -T /usr/bin/codesign -T /usr/bin/security -A")
    sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k #{keychain_password.shellescape} #{keychain_path.shellescape}")

    # Diagnostic: confirm exactly what got imported and whether the
    # system considers it a valid codesigning identity.
    sh("security find-identity -v -p codesigning #{keychain_path.shellescape} || true")

    profile_path = File.join(Dir.mktmpdir, "distribution.mobileprovision")
    File.binwrite(profile_path, Base64.decode64(ENV.fetch("IOS_PROVISIONING_PROFILE_BASE64")))
    install_provisioning_profile(path: profile_path)

    # install_provisioning_profile's return value is the file path it copied
    # the profile to (which can contain spaces, e.g. ".../Provisioning
    # Profiles/..."), not something PROVISIONING_PROFILE_SPECIFIER can use.
    # Xcode wants the profile's own UUID, decoded from its embedded plist.
    decoded_plist_path = File.join(Dir.mktmpdir, "profile.plist")
    sh("security cms -D -i #{profile_path.shellescape} > #{decoded_plist_path.shellescape}")
    profile_uuid = sh("/usr/libexec/PlistBuddy -c 'Print :UUID' #{decoded_plist_path.shellescape}").strip

    api_key_path = File.join(Dir.mktmpdir, "app_store_connect_api_key.p8")
    File.binwrite(api_key_path, Base64.decode64(ENV.fetch("APP_STORE_CONNECT_API_KEY_BASE64")))
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
      key_filepath: api_key_path,
    )

    # On a cold checkout, SPM hasn't fetched any packages yet, and
    # update_code_signing_settings's internal `xcodebuild
    # -showBuildSettings` call times out waiting on that first resolve
    # (its retry budget is only a few seconds). Warm the package cache
    # explicitly first so that call resolves instantly.
    # `sh` runs relative to this Fastfile's own folder (fastlane/), one
    # level below App.xcodeproj, so use an absolute path instead of
    # relying on a relative one.
    xcodeproj_path = File.expand_path("../App.xcodeproj", __dir__)
    sh("xcodebuild -resolvePackageDependencies -scheme App -project #{xcodeproj_path.shellescape}")

    # xcargs applies to every target in the build graph, including the
    # SPM package dependencies (Alamofire, Firebase, etc.) — those are
    # libraries and error out if forced into manual signing. Scope the
    # signing override to just the App target's own project settings
    # instead, which leaves the SPM packages on their own defaults.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "App.xcodeproj",
      team_id: "3783UTR3VM",
      code_sign_identity: "Apple Distribution",
      profile_uuid: profile_uuid,
      targets: ["App"],
    )

    build_app(
      project: "App.xcodeproj",
      scheme: "App",
      export_method: "app-store",
      # PRODUCT_NAME is "모아 moa" (Korean + space) — gym derives the
      # default output filename from it, which triggers a "same file"
      # FileUtils error when it tries to copy the built IPA into place.
      # Pin an ASCII-safe name and a dedicated output dir to sidestep it.
      output_directory: "build",
      output_name: "App",
    )

    # Diagnostic: show exactly what signed the exported .app, since the
    # upload keeps getting rejected for reasons that don't match what
    # we've configured so far.
    archive_path = lane_context[SharedValues::XCODEBUILD_ARCHIVE]
    app_path = Dir.glob(File.join(archive_path, "Products/Applications/*.app")).first
    sh("codesign -dvvv #{app_path.shellescape} 2>&1 || true") if app_path

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
