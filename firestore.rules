rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 로그인한 사용자만 접근 허용
    function isSignedIn() {
      return request.auth != null;
    }

    // 사용자 개인 문서 (문서 ID = uid)
    // 예: 예산(budgets), 고정지출(fixedExpenses), 카드, 계좌, 설정 등
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // 원격 설정 / 강제 업데이트 기준값 — 로그인 전에도 읽어야 하므로 공개 읽기 허용.
    // 클라이언트에서 직접 쓰지 못하게 하고, 값 갱신은 Firebase 콘솔에서 수동으로 한다.
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // 거래 내역 (각 문서의 uid 필드로 소유자 판별)
    match /transactions/{docId} {
      // 본인 소유 문서만 조회
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      // 생성 시 uid를 본인 것으로만 저장 가능
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      // 본인 소유 문서만 수정/삭제
      allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }
  }
}
